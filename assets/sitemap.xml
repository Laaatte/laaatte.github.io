---
layout: null
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset
  xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="
    http://www.sitemaps.org/schemas/sitemap/0.9
    http://www.sitemaps.org/schemas/sitemap/0.9/sitemap.xsd">

  {%- comment -%} Collections (posts, tabs, categories…) {%- endcomment -%}
  {%- assign collections = site.collections | where_exp: 'col', 'col.output != false' -%}

  {%- for col in collections -%}
    {%- assign docs = col.docs | where_exp: 'd', 'd.sitemap != false' -%}
    {%- for d in docs -%}
      <url>
        <loc>{{ d.url | replace:'/index.html','/' | absolute_url | xml_escape }}</loc>
        {%- if d.last_modified_at or d.date -%}
        <lastmod>{{ d.last_modified_at | default: d.date | date_to_xmlschema }}</lastmod>
        {%- endif -%}
      </url>
    {%- endfor -%}
  {%- endfor -%}

  {%- comment -%} HTML pages (excluding 404) {%- endcomment -%}
  {%- assign pages = site.html_pages
        | where_exp: 'p', 'p.sitemap != false'
        | where_exp: 'p', 'p.url != "/404.html"' -%}

  {%- for p in pages -%}
    <url>
      <loc>{{ p.url | replace:'/index.html','/' | absolute_url | xml_escape }}</loc>
      {%- if p.last_modified_at -%}
      <lastmod>{{ p.last_modified_at | date_to_xmlschema }}</lastmod>
      {%- endif -%}
    </url>
  {%- endfor -%}

  {%- comment -%} Static files (real Jekyll variable is site.static_files) {%- endcomment -%}
  {%- assign static_files = site.static_files
        | where_exp: 'f', 'f.sitemap != false'
        | where_exp: 'f', 'f.name != "404.html"' -%}

  {%- for f in static_files -%}
    <url>
      <loc>{{ f.path | replace:'/index.html','/' | absolute_url | xml_escape }}</loc>
      <lastmod>{{ f.modified_time | date_to_xmlschema }}</lastmod>
    </url>
  {%- endfor -%}

</urlset>