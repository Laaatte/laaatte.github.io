---
# jekyll processes this file as a template
layout: null
permalink: /posts.json
---
[
  {%- comment -%}
    loop through all posts in site.posts (sorted newest first)
  {%- endcomment -%}

  {%- for post in site.posts -%}
    {
      {%- comment -%}
        jsonify ensures safe json output for strings
      {%- endcomment -%}
      "title": {{ post.title | jsonify }},
      "url": {{ post.url | jsonify }},
      "date": "{{ post.date | date: "%Y-%m-%d" }}"
    }
    {%- unless forloop.last -%},{%- endunless -%}
  {%- endfor -%}
]